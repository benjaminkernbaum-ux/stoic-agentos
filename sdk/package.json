{
  "name": "stoic-agentos-sdk",
  "version": "3.0.0",
  "description": "Official SDK for Stoic AgentOS — AI Agent Operations Platform. Auto-instrument OpenAI & Anthropic calls. Monitor, orchestrate, and persist knowledge across your AI agent fleet.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    },
    "./instrument": {
      "import": "./src/instrument.js"
    }
  },
  "bin": {
    "agentos": "src/cli.js",
    "stoic-agentos-sdk": "src/cli.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "ai",
    "agents",
    "monitoring",
    "observability",
    "agent-ops",
    "llm",
    "orchestration",
    "ai-agents",
    "agent-monitoring",
    "knowledge-base",
    "stoic",
    "openai",
    "anthropic",
    "auto-instrumentation",
    "tracing",
    "agentos",
    "llm-observability"
  ],
  "author": "Benjamin Kernbaum <benjamin@stoicagentos.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/benjaminkernbaum-ux/stoic-agentos",
    "directory": "sdk"
  },
  "homepage": "https://stoicagentos.com/docs",
  "bugs": {
    "url": "https://github.com/benjaminkernbaum-ux/stoic-agentos/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true }
  },
  "dependencies": {},
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
