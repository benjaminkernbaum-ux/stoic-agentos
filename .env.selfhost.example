# ═══════════════════════════════════════════════════════
#  Stoic AgentOS — Self-Hosted Environment Variables
# ═══════════════════════════════════════════════════════
#
#  Copy this file to .env.selfhost and fill in your values:
#    cp .env.selfhost.example .env.selfhost
#
#  Then run:
#    docker compose -f docker-compose.selfhost.yml up -d

# ─── REQUIRED ───────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OPTIONAL: AI Features ─────────────────────────────
# Platform-wide Anthropic key (users can also BYOK per-org)
ANTHROPIC_API_KEY=

# ─── OPTIONAL: Billing ──────────────────────────────────
# Leave empty to disable Stripe billing (all orgs get free plan)
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ─── OPTIONAL: Production Rate Limiting ─────────────────
# Without Redis, rate limiting uses in-memory (works for single instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── OPTIONAL: Port Override ────────────────────────────
PORT=4444
