# ═══════════════════════════════════════════════════════
#  Stoic AgentOS — Self-Hosted Environment Variables
# ═══════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your values:
#    cp .env.selfhost.example .env
#
#  Then run:
#    docker compose up -d
#
#  See SELF_HOSTING.md for the full walkthrough (including migrations).

# ─── REQUIRED: your Supabase project → Settings → API ───
SUPABASE_URL=https://your-project.supabase.co
# Service-role key — server-side ONLY, never ships to the browser.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Anon (public) key — embedded in the dashboard build; public by design.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OPTIONAL: AI Features ─────────────────────────────
# Platform-wide Anthropic key (users can also BYOK per-org)
ANTHROPIC_API_KEY=

# ─── OPTIONAL: Billing ──────────────────────────────────
# Leave empty to disable Stripe billing (all orgs get free plan)
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ─── OPTIONAL: Production Rate Limiting ─────────────────
# Without Redis, rate limiting uses in-memory (works for a single instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── OPTIONAL: Ports & dashboard → API URL ──────────────
# The browser-reachable API URL the dashboard calls (must be reachable
# from the user's machine, not just from inside the Docker network).
VITE_API_URL=http://localhost:4444
API_PORT=4444
DASHBOARD_PORT=3000
