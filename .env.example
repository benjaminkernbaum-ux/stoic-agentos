# ═══════════════════════════════════════════════════════════
# STOIC AGENTOS — Environment Variables
# Copy to .env (frontend) or set in Railway / Vercel dashboards
# ═══════════════════════════════════════════════════════════

# ── Frontend (Vite — must be VITE_ prefixed) ──
VITE_SUPABASE_URL=https://viiagdhtzbvkfhcjqrlz.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=https://agent-ops-production.up.railway.app
VITE_TURNSTILE_SITE_KEY=           # Cloudflare Turnstile — get from https://dash.cloudflare.com → Turnstile

# ── API (api/, Railway) ──
PORT=4444
SUPABASE_URL=https://viiagdhtzbvkfhcjqrlz.supabase.co
SUPABASE_SERVICE_KEY=

# Anthropic (Claude) — platform-wide fallback key.
# Customers can also set their own per-org via POST /api-keys/anthropic.
ANTHROPIC_API_KEY=sk-ant-

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── MCP Server (mcp-server/) ──
AGENTOS_API_KEY=sk_live_
AGENTOS_API_URL=https://agent-ops-production.up.railway.app
INFRA_AGENT_PATH=
GITHUB_TOKEN=
# Used by Claude-powered MCP tools (agentos_summarize_observations, agentos_analyze_agent)
# Same key as the API service can be reused.
# ANTHROPIC_API_KEY=sk-ant-

# ── Cron Worker (api/src/cron/worker.ts) ──
# API key for the cron worker to call reflection/decay endpoints.
# Use any valid org API key. Without this, reflection is skipped.
CRON_API_KEY=sk_live_
